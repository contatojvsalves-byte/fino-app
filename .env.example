# ─────────────────────────────────────────
# Fino — .env.example
# Copie para .env.local e preencha os valores
# NUNCA commite o .env.local
# ─────────────────────────────────────────

# BANCO DE DADOS
# PostgreSQL local: postgresql://user:password@localhost:5432/fino
# Supabase:         postgresql://postgres:[senha]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/fino"

# NEXTAUTH
# Gere com: openssl rand -base64 32
AUTH_SECRET="seu-secret-super-seguro-aqui"
AUTH_URL="http://localhost:3000"

# GOOGLE OAUTH (opcional mas recomendado)
# Obtenha em: console.cloud.google.com → Credenciais → OAuth 2.0
AUTH_GOOGLE_ID="seu-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="seu-google-client-secret"

# ANTHROPIC (IA)
# Obtenha em: console.anthropic.com
# ⚠️ NUNCA exponha no frontend — apenas API routes usam isso
ANTHROPIC_API_KEY="sk-ant-api03-..."

# STRIPE (pagamentos — implementar no futuro)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# MERCADO PAGO (alternativa brasileira)
MERCADO_PAGO_ACCESS_TOKEN="APP_USR-..."

# APP
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Fino"

# RATE LIMITING (opcional — Redis)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
