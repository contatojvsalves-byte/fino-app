// prisma/schema.prisma
// Fino — Finanças Inteligentes
// Schema completo para SaaS financeiro

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// AUTENTICAÇÃO (NextAuth v5)
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  financialProfile FinancialProfile?
  transactions     Transaction[]
  budgetLimits     BudgetLimit[]
  debts            Debt[]
  aiConversations  AiConversation[]
  userPlan         UserPlan?
  categories       Category[]
  consentLogs      ConsentLog[]
  investments      Investment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────
// PERFIL FINANCEIRO
// ─────────────────────────────────────────

model FinancialProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  monthlyIncome    Decimal  @default(0) @db.Decimal(12, 2)
  savingGoalPercent Int     @default(20)
  currency         String   @default("BRL")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_profiles")
}

// ─────────────────────────────────────────
// CATEGORIAS
// ─────────────────────────────────────────

model Category {
  id        String       @id @default(cuid())
  userId    String?      // null = categoria padrão do sistema
  name      String
  icon      String       @default("📦")
  color     String       @default("#94a3b8")
  type      CategoryType
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgetLimits BudgetLimit[]

  @@map("categories")
}

enum CategoryType {
  INCOME
  EXPENSE
}

// ─────────────────────────────────────────
// TRANSAÇÕES
// ─────────────────────────────────────────

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  description   String
  categoryId    String
  date          DateTime
  paymentMethod String?
  isRecurring   Boolean         @default(false)
  notes         String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId, date])
  @@index([userId, type])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ─────────────────────────────────────────
// LIMITES DE ORÇAMENTO
// ─────────────────────────────────────────

model BudgetLimit {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  amount     Decimal  @db.Decimal(12, 2)
  month      String   // formato "YYYY-MM"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, month])
  @@map("budget_limits")
}

// ─────────────────────────────────────────
// DÍVIDAS
// ─────────────────────────────────────────

model Debt {
  id                  String     @id @default(cuid())
  userId              String
  name                String
  originalAmount      Decimal    @db.Decimal(12, 2)
  currentBalance      Decimal    @db.Decimal(12, 2)
  monthlyInterestRate Decimal    @default(0) @db.Decimal(5, 4)
  monthlyPayment      Decimal    @default(0) @db.Decimal(12, 2)
  dueDate             DateTime?
  status              DebtStatus @default(ACTIVE)
  notes               String?    @db.Text

  // Parcelamento
  isInstallment       Boolean    @default(false)
  totalInstallments   Int?
  paidInstallments    Int        @default(0)
  installmentDueDay   Int?       // dia do mês do vencimento

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments DebtPayment[]

  @@index([userId, status])
  @@map("debts")
}

model DebtPayment {
  id      String   @id @default(cuid())
  debtId  String
  amount  Decimal  @db.Decimal(12, 2)
  paidAt  DateTime @default(now())
  notes   String?

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@map("debt_payments")
}

enum DebtStatus {
  ACTIVE
  PARTIAL
  PAID
  NEGOTIATING
  DEFAULTED
}

// ─────────────────────────────────────────
// IA — CONVERSAS E MENSAGENS
// ─────────────────────────────────────────

model AiConversation {
  id        String      @id @default(cuid())
  userId    String
  title     String      @default("Nova conversa")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           AiRole
  content        String   @db.Text
  tokensUsed     Int?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

enum AiRole {
  USER
  ASSISTANT
}

// ─────────────────────────────────────────
// INVESTIMENTOS
// ─────────────────────────────────────────

model Investment {
  id           String         @id @default(cuid())
  userId       String
  ticker       String         // ex: PETR4, BTC, TESOURO-SELIC-2029
  name         String         // nome completo
  type         InvestmentType
  quantity     Decimal        @db.Decimal(18, 8)  // suporta frações de cripto
  avgPrice     Decimal        @db.Decimal(18, 6)  // preço médio de compra
  currentPrice Decimal        @default(0) @db.Decimal(18, 6) // atualizado via API
  broker       String?        // corretora
  notes        String?        @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions InvestmentTx[]

  @@index([userId, type])
  @@map("investments")
}

model InvestmentTx {
  id           String   @id @default(cuid())
  investmentId String
  type         String   // "BUY" | "SELL"
  quantity     Decimal  @db.Decimal(18, 8)
  price        Decimal  @db.Decimal(18, 6)
  total        Decimal  @db.Decimal(18, 2)
  date         DateTime
  fees         Decimal  @default(0) @db.Decimal(10, 4)
  notes        String?
  createdAt    DateTime @default(now())

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@map("investment_txs")
}

enum InvestmentType {
  STOCK      // ações
  FII        // fundos imobiliários
  ETF        // ETFs
  CRYPTO     // criptomoedas
  TREASURY   // tesouro direto
  GOLD       // ouro
  FIXED      // renda fixa (CDB, LCI, LCA)
  OTHER
}

// ─────────────────────────────────────────
// PLANO SaaS
// ─────────────────────────────────────────

model UserPlan {
  id                 String              @id @default(cuid())
  userId             String              @unique
  plan               PlanType            @default(FREE)
  aiMessagesUsed     Int                 @default(0)
  aiMessagesLimit    Int                 @default(5)
  transactionLimit   Int                 @default(50)
  subscriptionStatus SubscriptionStatus  @default(ACTIVE)
  paymentProvider    String?
  externalSubId      String?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean             @default(false)
  aiResetKey         String?             // formato "YYYY-MM" para controle mensal
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

enum PlanType {
  FREE
  PREMIUM
  ENTERPRISE // futuro
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

// ─────────────────────────────────────────
// LGPD — CONSENTIMENTO
// ─────────────────────────────────────────

model ConsentLog {
  id          String   @id @default(cuid())
  userId      String
  consentType String   // "ai_usage", "open_finance", "marketing"
  granted     Boolean
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
  @@map("consent_logs")
}
